{
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter './packages/*' build",
    "cleanup": "bun run --parallel --filter '*' cleanup && rimraf node_modules bun.lock",
    "lint": "oxlint",
    "fmt": "oxfmt",
    "prepare": "husky",
    "docs:dev": "bunx docsome dev DOCS.md",
    "docs:build": "bunx docsome build DOCS.md",
    "test": "bun run --parallel --filter './packages/*' test"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.8.8",
    "@types/bun": "^1.3.11",
    "docsome": "^0.0.6",
    "husky": "^9.1.7",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "rimraf": "^6.1.3",
    "tsdown": "^0.21.4",
    "typescript": "^6.0.2"
  }
}
